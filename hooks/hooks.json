{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_TOOLBOX_ROOT/scripts/validate-env.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_TOOLBOX_ROOT/scripts/setup-mcp.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_TOOLBOX_ROOT/scripts/collect-plan-map.py > /dev/null"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_TOOLBOX_ROOT/scripts/lint-py.py"
          }
        ]
      }
    ],
    "Notification": [],
    "PreCompact": [
      {
        "blockOnFailure": true,
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_TOOLBOX_ROOT/scripts/check-pin-ran.py"
          }
        ]
      }
    ]
  }
}
